# Vercelの「Settings → Environment Variables」で設定してください。値をGitにコミットしないこと。

# OpenAI API（必須）
OPENAI_API_KEY=

# GitHub API（オプション。未設定でも鑑定は動作するが、レート制限が厳しくなる場合あり）
# GITHUB_TOKEN=

# Clerk認証（Clerk利用時）
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# 本番のベースURL（OGP・シェア用。Vercelでは VERCEL_URL が自動設定される）
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# アフィリエート・問い合わせ（任意）
# NEXT_PUBLIC_AFFILIATE_BUSINESS_STEP1=
# NEXT_PUBLIC_AFFILIATE_BUSINESS_STEP2=
# NEXT_PUBLIC_STRIPE_CHECKOUT_URL=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_CONTACT_FORM_URL=
# NEXT_PUBLIC_CONTACT_GOOGLE_FORM=
# NEXT_PUBLIC_CONTACT_X_DM=
# NEXT_PUBLIC_CONTACT_EMAIL=
